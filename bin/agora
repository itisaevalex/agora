#!/usr/bin/env bash
# agora wrapper. Installed at ~/.local/bin/agora by install.sh.
# Locates the repo via AGORA_REPO or falls back to the install-time path.
set -e

REPO="${AGORA_REPO:-__AGORA_REPO_PLACEHOLDER__}"

if [[ ! -f "$REPO/lib/cli.py" ]]; then
    echo "agora: cli.py not found at $REPO/lib/cli.py" >&2
    echo "agora: set AGORA_REPO=/path/to/agora to override" >&2
    exit 2
fi

exec python3 "$REPO/lib/cli.py" "$@"
