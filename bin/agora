#!/usr/bin/env bash
# aoe-bus wrapper. Installed at ~/.local/bin/aoe-bus by install.sh.
# Locates the repo via AOE_BUS_REPO or falls back to the install-time path.
set -e

REPO="${AOE_BUS_REPO:-__AOE_BUS_REPO_PLACEHOLDER__}"

if [[ ! -f "$REPO/lib/cli.py" ]]; then
    echo "aoe-bus: cli.py not found at $REPO/lib/cli.py" >&2
    echo "aoe-bus: set AOE_BUS_REPO=/path/to/aoe-bus to override" >&2
    exit 2
fi

exec python3 "$REPO/lib/cli.py" "$@"
